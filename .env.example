# Copy to ".env" in the project root. The server loads it automatically (godotenv) when you run from that directory.
#
# HTTP server listen address
# e.g. ":8080" or "0.0.0.0:8080"
SERVER_ADDR=:8080

# CORS for standalone Playground calling /api/event: * allows any Origin; use comma-separated allowlist in production
CORS_ALLOWED_ORIGINS=*
# CORS_ALLOWED_ORIGINS=http://localhost:3000,https://play.example.com

# WebSocket JWT (HS256). If set, clients must send a valid JWT; user id comes from claims (see JWT_USER_CLAIM).
# Leave unset to allow legacy ?user_id= for local dev.
JWT_SECRET=secret
JWT_USER_CLAIM=sub

# Redis for Presence store and Presence MQ delivery
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

# Presence TTL (seconds); clients should send presence_update within this window as heartbeat
PRESENCE_TTL_SECONDS=60

# Broadcast MQ plugin name
# - default: redis
# - extend with kafka, rabbitmq, etc. (implement and register the plugin)
BROADCAST_MQ_TYPE=redis

# Broadcast MQ connection (when BROADCAST_MQ_TYPE=redis, this is the Redis used for broadcast pub/sub)
# May match Presence Redis or point to a dedicated instance
BROADCAST_MQ_ADDR=127.0.0.1:6379
BROADCAST_MQ_PASSWORD=
BROADCAST_MQ_DB=0


JWT_SECRET=xx

# -----------------------------------------------------------------------------
# Kafka (example; only effective after implementing BROADCAST_MQ_TYPE=kafka)
# -----------------------------------------------------------------------------
# BROADCAST_MQ_TYPE=kafka
#
# # Comma-separated brokers
# BROADCAST_KAFKA_BROKERS=127.0.0.1:9092
#
# # Topic for broadcast (often one topic + partition by channel key)
# BROADCAST_KAFKA_TOPIC=realtime-broadcast
#
# # Consumer group (gateway instances may share one group)
# BROADCAST_KAFKA_GROUP=realtime-gateway
#
# # Optional: SASL/TLS
# BROADCAST_KAFKA_SASL_ENABLED=false
# BROADCAST_KAFKA_SASL_USERNAME=
# BROADCAST_KAFKA_SASL_PASSWORD=
# BROADCAST_KAFKA_TLS_ENABLED=false
# BROADCAST_KAFKA_TLS_CA_FILE=
#
# -----------------------------------------------------------------------------
# RabbitMQ (example; only effective after implementing BROADCAST_MQ_TYPE=rabbitmq)
# -----------------------------------------------------------------------------
# BROADCAST_MQ_TYPE=rabbitmq
#
# # Connection URL
# BROADCAST_RABBITMQ_URL=amqp://guest:guest@127.0.0.1:5672/
#
# # Exchange and routing (example: topic exchange)
# BROADCAST_RABBITMQ_EXCHANGE=realtime
# BROADCAST_RABBITMQ_EXCHANGE_TYPE=topic
# BROADCAST_RABBITMQ_ROUTING_KEY_PREFIX=broadcast.
#
# # Queue (often exclusive per gateway instance, or name suffixed with instance id)
# BROADCAST_RABBITMQ_QUEUE=realtime-gateway
# BROADCAST_RABBITMQ_QUEUE_EXCLUSIVE=true
# BROADCAST_RABBITMQ_QUEUE_AUTO_DELETE=true

